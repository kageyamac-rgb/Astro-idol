---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// 画像のインポート
import img1 from '../assets/nyugaku.svg';
import img2 from '../assets/wakaru.png';
import img3 from '../assets/eikaiwa.svg';
import img4 from '../assets/shikenbenkyou.svg';
import img5 from '../assets/soudan.svg';

const pageTitle = "私立中学サポート | 鳴滝塾";
---

<Layout title={pageTitle}>
  <Header />

  <main id="naru-root" style="background-color: #ffffff; color: #222; padding: 40px 0; overflow-x: hidden; width: 100%;">
    
    <header style="max-width: 900px; margin: 0 auto 40px; width: 95%; text-align: center;">
      <span style="color: #001530; font-weight: 800; font-size: 1.1rem; letter-spacing: 0.1em;">PRIVATE SCHOOL SUPPORT</span>
      <h1 style="font-size: 2.8rem; font-weight: 900; color: #001530; margin: 5px 0; line-height: 1.1;">私立中学学習サポートコース</h1>
      <p style="font-size: 1.4rem; color: #666; line-height: 1.4; margin: 0;">中学受験はゴールではない。新しい6年間の「勉強の仕方」を導きます。</p>
    </header>

    <div style="max-width: 900px; margin: 0 auto; width: 95%;">

      <section class="n-block" style="display: flex; align-items: flex-start; justify-content: space-between; margin: 0 !important; padding: 10px 0 !important; width: 100%; border-bottom: 1px solid #f0f0f0;">
        <div class="n-col-img" style="width: 44%; margin: 0 !important;">
          <img src={img1.src} alt="入学後の悩み" style="width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.05));" />
        </div>
        <div class="n-col-txt" style="width: 53%; margin: 0 !important;">
          <h2 style="font-size: 2.0rem; font-weight: 900; color: #001530; line-height: 1.3; margin: 0 0 10px 0 !important;">「合格したのに、勉強法がわからない」そんな悩みに。</h2>
          <div class="n-notebook">
            <p class="n-text" style="font-size: 1.8rem; font-weight: 600; line-height: 1.8; color: #333; margin: 0 !important; background-image: linear-gradient(transparent 95%, #eee 95%); background-size: 100% 3.24rem; background-position: 0 0.4rem;">
              念願の私立中学に入学したものの、膨大な課題や速い授業スピードに「どう勉強すればいいかわからない」と戸惑う生徒は少なくありません。当塾では、ノートの取り方や予習復習の組み立て方から丁寧に指導します。他塾で中学受験を終えたお子様も大歓迎です。ゼロから「私立での勝ち方」を教えます。
            </p>
          </div>
        </div>
      </section>

      <section class="n-block n-rev" style="display: flex; flex-direction: row-reverse; align-items: flex-start; justify-content: space-between; margin: 0 !important; padding: 10px 0 !important; width: 100%; border-bottom: 1px solid #f0f0f0;">
        <div class="n-col-img" style="width: 44%; margin: 0 !important;">
          <img src={img2.src} alt="数学フォロー" style="width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.05));" />
        </div>
        <div class="n-col-txt" style="width: 53%; margin: 0 !important;">
          <h2 style="font-size: 2.0rem; font-weight: 900; color: #001530; line-height: 1.3; margin: 0 0 10px 0 !important;">私立の高速カリキュラム。三角関数が出ても大丈夫。</h2>
          <div class="n-notebook">
            <p class="n-text" style="font-size: 1.8rem; font-weight: 600; line-height: 1.8; color: #333; margin: 0 !important; background-image: linear-gradient(transparent 95%, #eee 95%); background-size: 100% 3.24rem; background-position: 0 0.4rem;">
              私立中学の進度は非常に速く、中2や中3で高校数学の「三角関数」や「数I・A」が平気で登場します。鳴滝塾では、各学校の進度をリアルタイムにフォロー。難解な高校範囲であっても、個別指導で噛み砕いて解説します。「分からない」を翌週に持ち越さない、先回りした指導で成績上位を維持させます。
            </p>
          </div>
        </div>
      </section>

      <section class="n-block" style="display: flex; align-items: flex-start; justify-content: space-between; margin: 0 !important; padding: 10px 0 !important; width: 100%; border-bottom: 1px solid #f0f0f0;">
        <div class="n-col-img" style="width: 44%; margin: 0 !important;">
          <img src={img3.src} alt="英語対策" style="width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.05));" />
        </div>
        <div class="n-col-txt" style="width: 53%; margin: 0 !important;">
          <h2 style="font-size: 2.0rem; font-weight: 900; color: #001530; line-height: 1.3; margin: 0 0 10px 0 !important;">英語は「学校の教材」が最強。徹底した教科書準拠。</h2>
          <div class="n-notebook">
            <p class="n-text" style="font-size: 1.8rem; font-weight: 600; line-height: 1.8; color: #333; margin: 0 !important; background-image: linear-gradient(transparent 95%, #eee 95%); background-size: 100% 3.24rem; background-position: 0 0.4rem;">
              ニュートレジャーやプログレスといった私立特有の難解教材は、塾の汎用テキストでは対応できません。当塾では学校の教材やプリントをそのまま持ち込み、先生の出題傾向に合わせて対策します。教科書を徹底的に使い倒すことで、大学入試まで揺るがない英語の「地頭」を構築します。
            </p>
          </div>
        </div>
      </section>

      <section class="n-block n-rev" style="display: flex; flex-direction: row-reverse; align-items: flex-start; justify-content: space-between; margin: 0 !important; padding: 10px 0 !important; width: 100%; border-bottom: 1px solid #f0f0f0;">
        <div class="n-col-img" style="width: 44%; margin: 0 !important;">
          <img src={img4.src} alt="定期テスト対策" style="width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.05));" />
        </div>
        <div class="n-col-txt" style="width: 53%; margin: 0 !important;">
          <h2 style="font-size: 2.0rem; font-weight: 900; color: #001530; line-height: 1.3; margin: 0 0 10px 0 !important;">テスト前の「補習」で、圧倒的な勉強時間を確保。</h2>
          <div class="n-notebook">
            <p class="n-text" style="font-size: 1.8rem; font-weight: 600; line-height: 1.8; color: #333; margin: 0 !important; background-image: linear-gradient(transparent 95%, #eee 95%); background-size: 100% 3.24rem; background-position: 0 0.4rem;">
              成績を左右するのは、結局「集中して机に向かった時間」です。部活や通学で忙しい私立生のために、テスト2週間前からは塾での時間を強制的に確保。静かな環境で学校の課題を完璧に仕上げ、分からない箇所はその場で即解決。この「演習量」が、私立校内での確実な順位アップを支えます。
            </p>
          </div>
        </div>
      </section>

      <section class="n-block" style="display: flex; align-items: flex-start; justify-content: space-between; margin: 0 !important; padding: 10px 0 !important; width: 100%;">
        <div class="n-col-img" style="width: 44%; margin: 0 !important;">
          <img src={img5.src} alt="進路相談" style="width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.05));" />
        </div>
        <div class="n-col-txt" style="width: 53%; margin: 0 !important;">
          <h2 style="font-size: 2.0rem; font-weight: 900; color: #001530; line-height: 1.3; margin: 0 0 10px 0 !important;">高校進学、文理選択。中だるみを防ぐ進路相談。</h2>
          <div class="n-notebook">
            <p class="n-text" style="font-size: 1.8rem; font-weight: 600; line-height: 1.8; color: #333; margin: 0 !important; background-image: linear-gradient(transparent 95%, #eee 95%); background-size: 100% 3.24rem; background-position: 0 0.4rem;">
              高校受験がないからこそ訪れる「中だるみ」。鳴滝塾は学習指導だけでなく、高校進学時のコース選択や将来の大学受験を見据えた進路相談を随時実施。他塾からの転塾生であっても、歩みを尊重しながら鳴滝塾流の「自学の型」を伝授。目標を見失わず、6年間を駆け抜ける支えとなります。
            </p>
          </div>
        </div>
      </section>
    </div>

    <div style="background-color: #f9f9f9; padding: 40px 0; margin-top: 10px;">
      <div style="max-width: 800px; margin: 0 auto; width: 90%;">
        <h2 style="text-align: center; margin-bottom: 30px; font-weight: 900; font-size: 2.2rem;">よくある質問</h2>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {[
            {q: "他塾で受験をしましたが、ついていけますか？", a: "もちろんです。むしろ、新しい環境でリセットしたい外部生の方は多いです。現状の学力に合わせた学習プランを一緒に立てましょう。"},
            {q: "学校のプリントが特殊なのですが...", a: "私立校は独自のプリント教材が命です。それらをすべて塾へ持ち込んでください。学校の先生の癖に合わせた対策を行います。"},
            {q: "高校受験コースとの違いは？", a: "高校受験コースが内申点重視なのに対し、本コースは学校の高度な先取り授業の理解と定期テストでの高得点を最優先します。"}
          ].map(faq => (
            <div style="background: white; padding: 20px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
              <p style="font-size: 1.4rem; font-weight: 900; color: #001530; margin:0 !important;">Q. {faq.q}</p>
              <p style="font-size: 1.2rem; color: #555; margin: 8px 0 0 0 !important; line-height: 1.5;" set:html={`A. ${faq.a}`}></p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div style="text-align: center; padding: 80px 0;">
       <a href="/" style="background: #001530; color: #fff; padding: 15px 50px; font-size: 1.6rem; border-radius: 50px; font-weight: 800; text-decoration: none; display: inline-block;">ホームへ戻る</a>
       <p style="margin-top: 50px; font-size: 1.8rem; font-weight: 900; color: #001530; font-style: italic;">"Start here, Fly higher."</p>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  section, div, h2, p, ul, li { margin-top: 0 !important; }

  @media (max-width: 999px) {
    .n-block { flex-direction: column !important; margin-bottom: 40px !important; }
    .n-rev { flex-direction: column !important; }
    .n-col-img, .n-col-txt { width: 100% !important; }
    .n-col-img { margin-bottom: 20px !important; }
    h1 { font-size: 2.2rem !important; }
    h2 { font-size: 1.8rem !important; }
    .n-text, .n-notebook p { font-size: 1.6rem !important; background-size: 100% 2.88rem !important; }
  }
</style>