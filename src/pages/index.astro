---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Trial from '../components/Trial.astro';
import News from '../components/News.astro'; // 1. Newsをインポート
import Concept from '../components/Concept.astro';
import Brief from '../components/Brief.astro';
import Pricing from '../components/Pricing.astro';
import Tables from '../components/Tables.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Access from '../components/Access.astro';
import Footer from '../components/Footer.astro';

import { createClient } from "microcms-js-sdk";
const client = createClient({
  serviceDomain: import.meta.env.MICROCMS_SERVICE_DOMAIN,
  apiKey: import.meta.env.MICROCMS_API_KEY,
});

const response = await client.get({ 
  endpoint: "information",
  queries: { limit: 5 }
});
---

<Layout title="鳴滝塾 | 少人数制の学習塾">
    <Header />
    <Hero />
    <Trial />
    <News contents={response.contents} />
    <Concept /> 
    <Brief />
    <Pricing />
    <Tables />
    <FAQ />
    <Contact />
    <Access />
    <Footer />
</Layout>