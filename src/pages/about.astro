---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

// 画像のインポート
import coffeeImg from '../assets/coffee.png'; 
import kodomoImg from '../assets/kodomosainou.png';
import pencilImg from '../assets/pencil.png';
---

<Layout title="鳴滝塾について | About Us">
  <Header />
  
  <main class="about-container">
    <section class="zigzag-section">
      <div class="content">
        <span class="sub-title">ABOUT US</span>
        <h2>鳴滝塾について</h2>
        <p>尾張旭の地で、長きに渡り学習のサポートを続けています。地域の皆さまとともに、学びと成長の道を歩んでまいりました。地元密着型ではありますが、昔も今も周辺の地域から幅広く通塾していただいています。</p>
        <p>小学生には絵描き算数教室『どんぐり倶楽部公式準拠教室』を、中学生には寺子屋式の少人数制学習塾を提供。明るい将来のために、ともに子供たちの成長を大学入試までサポートしています。</p>
        <p>小学生も中高生も少人数制にこだわっています。「ひとり一人しっかり目をかけ、個性にあった成長をサポートする。」ことがこだわりです。</p>
      </div>
      <div class="image-area">
        <Image src={pencilImg} alt="鉛筆とノート" />
      </div>
    </section>

    <section class="zigzag-section dark-bg reverse">
      <div class="content">
        <h2>提供しているもの</h2>
        <div class="service-list">
          <p>
            <strong>01-小学生の『どんぐり倶楽部公式準拠教室』</strong>
            絵解きでとける応用問題を提供しています。独自問題も多数あります。
          </p>
          <p>
            <strong>02-短期で中学受験</strong>
            学力よりちょっと背伸びをした中学受験をします。全科目をコントロールして無駄なく、ストレス少な目で、中高一貫中学を1年で合格に導きます。
          </p>
          <p>
            <strong>03-中学生の地元密着型少人数制学習塾</strong>
            定期テスト対策中心でおこない、内申点重視の愛知県公立高校入試に特化した全科目学習サポートを提供しています。
          </p>
          <p>
            <strong>04-高校生の推薦,総合型選抜,一般入試サポート</strong>
            高1の1学期から推薦入試に向け、内申点を上げるための定期テスト対策と、難関校合格を目指す受験生のための綿密な受験対策を実施しています。
          </p>
          <p>
            <strong>05-new!私立中学生のサポート</strong>
            私立中学に通っている生徒のための特別サポートを提供しています。
          </p>
        </div>
      </div>
      <div class="image-area">
        <Image src={coffeeImg} alt="コーヒーとノート" />
      </div>
    </section>

    <section class="zigzag-section">
      <div class="content">
        <h2>こどもの個性をつぶさない</h2>
        <p>子供たちは皆、独自の才能を持っています。その柔軟な発想力や創造性は、大人の想像を超えることもあります。</p>
        <p>勉強とは、ただ学校の授業をこなすことではありません。失敗や成功を通じて、「何をどうするか？」を自ら発見する過程が重要なのです。</p>
        <p>そのために、一人ひとりの学力、学習ペース、自己発信力に合わせて、「ゆっくり・じっくり・丁寧に」というスタイルで、真の学力を育みます。</p>
      </div>
      <div class="image-area">
        <Image src={kodomoImg} alt="絵を描く子供たち" />
      </div>
    </section>

    <section class="profile-section-final">
      <div class="profile-flex-container">
        <div class="profile-block-item left-item">
          <p class="p-role">MANAGER, TEACHER, DESIGNER</p>
          <h3 class="p-name">Masanori Kageyama</h3>
        </div>

        <div class="profile-block-item center-item">
          <h4 class="p-title">私について</h4>
          <div class="p-bio">
            <p>鳴滝塾の経営、講師をやっております。</p>
            <p>愛知県名古屋市出身、滝高校卒業</p>
            <p>名古屋大学工学部卒業</p>
            <br />
            <p>過去慶応大学SFCと共同研究</p>
            <p>10年連続共通テスト受験(センターテスト)</p>
          </div>
        </div>

        <div class="profile-block-item right-item">
          <a href="/" class="yellow-back-btn">戻る</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-container {
    width: 100%;
    overflow-x: hidden; /* 横揺れ防止 */
    background-color: #fff;
  }

  /* --- ジグザグセクション基本設定 --- */
  .zigzag-section {
    display: flex;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
    padding: 100px 20px;
    gap: 60px;
  }

  .zigzag-section.reverse {
    flex-direction: row-reverse;
  }

  /* 紺色背景の全幅化設定 */
  .dark-bg {
    background-color: #001530;
    color: #fff;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    position: relative;
    padding-inline: calc((100vw - 900px) / 2 + 20px);
  }

  .content { flex: 1.1; }

  /* 画像エリア：正方形・角丸・影 */
  .image-area {
    flex: 1;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  }

  .image-area img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  /* テキスト設定 */
  .sub-title { color: #d35400; font-size: 0.9rem; font-weight: bold; }
  h2 { font-size: 2.2rem; margin-bottom: 30px; font-weight: 700; color: #001530; }
  .dark-bg h2 { color: #fff; }

  .content p {
    font-size: 1.5rem; 
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: inherit;
  }

  /* サービスリスト */
  .service-list strong {
    font-size: 1.8rem;
    color: #fff;
    display: block;
    margin-top: 2.5rem; 
    margin-bottom: -0.2rem;
    font-weight: 800;
    line-height: 1.2;
  }
  .service-list p { margin-top: 0; }

  /* --- プロフィールセクション --- */
  
  .profile-section-final {
    padding: 100px 20px;
    max-width: 1000px;
    margin: 60px auto 0;
    border-top: 1px solid #eee;
  }

  .profile-flex-container {
    display: flex;
    /* ボタンを中央ブロックに密着させるため左寄せ */
    justify-content: flex-start; 
    align-items: flex-start;
    gap: 40px;
  }

  /* 左：名前エリア */
  .left-item {
    flex: 0 0 250px; /* 幅を固定して安定させる */
  }
  .p-role { 
    font-size: 1.5rem; 
    color: #888; 
    margin-bottom: 8px; 
    font-weight: bold;
    letter-spacing: 0.1em;
  }
  .p-name { 
    font-size: 2.2rem; 
    color: #001530; 
    font-weight: 700; 
    line-height: 1.2;
  }

  /* 中央：見出しと本文 */
  .center-item {
    flex: 0 1 auto; /* コンテンツに合わせて伸縮 */
  }
  .p-title { 
    font-size: 2.0rem; 
    margin-bottom: 25px; 
    font-weight: 700; 
    color: #001530; 
  }
  .p-bio p {
    font-size: 1.6rem !important; 
    line-height: 1.9 !important;
    margin-bottom: 8px !important;
    color: #333 !important;
  }

  /* 右：ボタンエリア */
  .right-item { 
    flex: 0 0 auto;
    padding-top: 10px; /* 見出しの高さに微調整 */
  }

  /* 戻るボタンをカプセル型に統一 */
  .yellow-back-btn {
    background: #ffd700;
    padding: 15px 45px;
    font-size: 1.2rem;
    text-decoration: none;
    color: #000;
    font-weight: bold;
    border-radius: 50px; 
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  /* 矢印を擬似要素で追加 */
  .yellow-back-btn::before {
    content: "←";
    font-size: 1.4rem;
  }

  .yellow-back-btn:hover {
    background: #fcc200;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  /* --- レスポンシブ --- */
  @media (max-width: 768px) {
    .zigzag-section, .zigzag-section.reverse {
      flex-direction: column;
      text-align: left;
      padding: 60px 20px;
      gap: 40px;
    }
    .dark-bg {
      width: 100%;
      margin: 0;
      padding-inline: 20px;
    }
    .image-area {
      max-width: 100%;
      aspect-ratio: 4 / 3;
    }
    .profile-flex-container {
      flex-direction: column;
      gap: 40px;
    }
    .left-item, .center-item, .right-item {
      flex: none;
      width: 100%;
      text-align: left;
    }
  }
</style>