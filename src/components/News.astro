---
// src/components/News.astro
// propsの型を定義（microCMSから来るデータの形を教える）
interface Props {
  contents: any[];
}

const { contents } = Astro.props;

// パラメーター 'html' に : string (文字列だよ) と付ける
const getExcerpt = (html: string) => {
  const text = html.replace(/<[^>]*>?/gm, ''); 
  return text.length > 20 ? text.substring(0, 20) + "..." : text;
};
---

<section class="news-section">
  <div class="container">
    <h2 class="news-heading">最新のお知らせ</h2>
    <div class="news-grid">
      {/* (info) に : any (なんでもいいよ) と付ける */}
      {contents.map((info: any) => (
        <a href={`/information/${info.id}`} class="news-item">
          <span class="date">{new Date(info.createdAt).toLocaleDateString('ja-JP')}</span>
          <h3 class="title">{info.title}</h3>
          <p class="excerpt">{getExcerpt(info.content)}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .news-section {
    // 上下の余白を大幅にカット (80px → 30px)
    padding: 30px 0; 
    background-color: #fff4eb; 
  }
  
  .news-heading {
    text-align: center;
    font-size: 2.2rem; // 少し小さくしてスッキリ
    margin-bottom: 20px; // タイトルと記事の間を詰める (50px → 20px)
    color: #b33e00;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .news-grid {
    display: flex;
    flex-direction: column;
    gap: 10px; // 記事同士の間隔をさらに詰める (15px → 10px)
  }

  .news-item {
    display: block;
    padding: 20px 25px; // 記事内の余白も少し詰める
    background: #ffffff;
    border-radius: 15px; // 少しコンパクトに
    border: 2px solid #f9e1d0;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 10px rgba(180, 80, 0, 0.05);

    &:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(180, 80, 0, 0.12);
    }

    .date { 
      color: #b38b7a; 
      font-size: 1.2rem; 
      font-weight: 700;
    }
    .title { 
      color: #1a1a1a; 
      font-size: 1.9rem; // 少しだけサイズダウン
      margin: 2px 0 5px; // タイトル上下の隙間を最小限に
    }
    .excerpt { 
      color: #555; 
      font-size: 1.4rem;
      line-height: 1.5;
    }
  }
</style>