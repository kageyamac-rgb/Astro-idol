---
// 右側のアイコン用
import Bolt from '../assets/bolt.svg'

// ボタンの共通スタイル（文字を少し大きく、スマホでも存在感を出しました）
const btnStyle = "display: inline-block; margin-top: 15px; background: #001530; color: #fff; padding: 14px 40px; font-size: clamp(1.1rem, 3vw, 1.2rem); border-radius: 50px; font-weight: 800; text-decoration: none; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: fit-content;";
---

<section class="product-brief" id="features" style="background-color: #f4f7f9; padding: 60px 0; overflow: hidden;">
  <div class="container">

    <div class="row product-brief-items" style="display: flex; align-items: center; flex-wrap: wrap; margin-bottom: clamp(40px, 10vw, 80px);">
      <div class="one-half column" style="background-color: #1a365d !important; display: flex; align-items: center; justify-content: center; padding: clamp(40px, 8vw, 60px) 15px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); width: 100%; max-width: 540px; min-height: auto;">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span style="font-size: clamp(2.2rem, 6vw, 4.2rem) !important; font-weight: 900 !important; line-height: 1;">小学生1年〜6年</span>
            <span style="font-size: clamp(2.8rem, 8vw, 5.5rem) !important; font-family: sans-serif; font-weight: bold; line-height: 1;">›</span>
          </div>
          <div style="margin-bottom: 25px;">
            <p style="font-size: clamp(1.4rem, 4vw, 2.4rem) !important; font-weight: bold !important; margin: 0 0 10px 0;">考える力を養成する</p>
            <p style="font-size: clamp(1.4rem, 4vw, 2.8rem) !important; font-weight: 800 !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 6px 20px; border-radius: 50px; margin: 0;">絵解き算数教室</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 12px clamp(20px, 5vw, 45px); margin-top: 10px; width: fit-content; max-width: 95%;">
            <h3 style="font-size: clamp(1.8rem, 5vw, 3rem) !important; font-weight: 900 !important; color: #ffffff !important; margin: 0; white-space: nowrap;">「どんぐり倶楽部」</h3>
          </div>
        </div>
      </div>
      <div class="brief-tab one-half column" style="padding: 30px clamp(0px, 5vw, 50px); flex: 1; min-width: 300px;">
        <h3 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: bold; margin-bottom: 15px; line-height: 1.3;">算数の応用問題を絵図を使いながら解きます</h3>
        <p style="font-size: 1.15rem; line-height: 1.6; color: #666; margin-bottom: 20px;">絵図を書いて考えることで、子供たちの思考力を引き出し、算数の問題を解く楽しさを体験させます。</p>
        <a href="/donguri" style={btnStyle}>どんぐりを詳しく見る →</a>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; flex-wrap: wrap-reverse; margin-bottom: clamp(40px, 10vw, 80px);">
      <div class="brief-tab one-half column" style="padding: 30px clamp(0px, 5vw, 50px); flex: 1; min-width: 300px;">
        <h3 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: bold; margin-bottom: 15px; line-height: 1.3;">短期で私立中学を受験するコースです</h3>
        <p style="font-size: 1.15rem; line-height: 1.6; color: #666; margin-bottom: 20px;">大手の塾で勉強付けは少し苦手、学力にあった学校に合格したい。短期集中で無理なく学びます。</p>
        <a href="/chugakujuken" style={btnStyle}>中学受験を詳しく見る →</a>
      </div>
      <div class="one-half column" style="background-color: #96514d !important; display: flex; align-items: center; justify-content: center; padding: clamp(40px, 8vw, 60px) 15px; border-radius: 8px; width: 100%; max-width: 540px; min-height: auto;">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span style="font-size: clamp(2.8rem, 8vw, 5.5rem) !important; font-family: sans-serif; font-weight: bold; line-height: 1;">‹</span>
            <span style="font-size: clamp(2.2rem, 6vw, 4.2rem) !important; font-weight: 900 !important; line-height: 1;">小学生5年, 6年</span>
          </div>
          <div style="margin-bottom: 25px;">
            <p style="font-size: clamp(1.4rem, 4vw, 2.6rem) !important; font-weight: bold !important; margin: 0;">短期集中で無理なく受験</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 12px clamp(20px, 5vw, 45px); margin-top: 10px; width: fit-content; max-width: 95%;">
            <h3 style="font-size: clamp(1.8rem, 5vw, 3rem) !important; font-weight: 900 !important; color: #ffffff !important; margin: 0; white-space: nowrap;">「中学受験コース」</h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; flex-wrap: wrap; margin-bottom: clamp(40px, 10vw, 80px);">
      <div class="one-half column" style="background-color: #2d5a27 !important; display: flex; align-items: center; justify-content: center; padding: clamp(40px, 8vw, 60px) 15px; border-radius: 8px; width: 100%; max-width: 540px; min-height: auto;">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span style="font-size: clamp(2.2rem, 6vw, 4.2rem) !important; font-weight: 900 !important; line-height: 1;">中学生 1〜3年</span>
            <span style="font-size: clamp(2.8rem, 8vw, 5.5rem) !important; font-family: sans-serif; font-weight: bold; line-height: 1;">›</span>
          </div>
          <div style="margin-bottom: 25px;">
            <p style="font-size: clamp(1.4rem, 4vw, 2.4rem) !important; font-weight: bold !important; margin: 0 0 10px 0;">学校の補習から定期テストまで</p>
            <p style="font-size: clamp(1.4rem, 4vw, 2.4rem) !important; font-weight: 800 !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 6px 20px; border-radius: 50px; margin: 0;">個別対応の学習支援</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 12px clamp(20px, 5vw, 45px); margin-top: 10px; width: fit-content; max-width: 95%;">
            <h3 style="font-size: clamp(1.8rem, 5vw, 3rem) !important; font-weight: 900 !important; color: #ffffff !important; margin: 0; white-space: nowrap;">「中学寺子屋コース」</h3>
          </div>
        </div>
      </div>
      <div class="brief-tab one-half column" style="padding: 30px clamp(0px, 5vw, 50px); flex: 1; min-width: 300px;">
        <h3 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: bold; margin-bottom: 15px; line-height: 1.3;">定期テスト・内申対策</h3>
        <p style="font-size: 1.15rem; line-height: 1.6; color: #666; margin-bottom: 20px;">寺子屋式で目の前で先生がサポートします。定期テスト無料補習で徹底サポート。</p>
        <a href="/chugakuterakoya" style={btnStyle}>中学寺子屋を詳しく見る →</a>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; flex-wrap: wrap-reverse; margin-bottom: clamp(40px, 10vw, 80px);">
      <div class="brief-tab one-half column" style="padding: 30px clamp(0px, 5vw, 50px); flex: 1; min-width: 300px;">
        <h3 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: bold; margin-bottom: 15px; line-height: 1.3;">私立独自の早い進度に対応します</h3>
        <p style="font-size: 1.15rem; line-height: 1.6; color: #666; margin-bottom: 20px;">公立とは異なるカリキュラム。私立ならではの悩みと進度を個別でサポート。</p>
        <a href="/shiritsuchugaku" style={btnStyle}>私立中サポートを詳しく見る →</a>
      </div>
      <div class="one-half column" style="background-color: #4a235a !important; display: flex; align-items: center; justify-content: center; padding: clamp(40px, 8vw, 60px) 15px; border-radius: 8px; width: 100%; max-width: 540px; min-height: auto;">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span style="font-size: clamp(2.8rem, 8vw, 5.5rem) !important; font-family: sans-serif; font-weight: bold; line-height: 1;">‹</span>
            <span style="font-size: clamp(2.2rem, 6vw, 4.2rem) !important; font-weight: 900 !important; line-height: 1;">私立中学 1〜3年</span>
          </div>
          <div style="margin-bottom: 25px;">
            <p style="font-size: clamp(1.4rem, 4vw, 2.6rem) !important; font-weight: bold !important; margin: 0;">一貫校のスピードに負けない</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 12px clamp(20px, 5vw, 45px); margin-top: 10px; width: fit-content; max-width: 95%;">
            <h3 style="font-size: clamp(1.8rem, 5vw, 3rem) !important; font-weight: 900 !important; color: #ffffff !important; margin: 0; white-space: nowrap;">「私立中サポート」</h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; flex-wrap: wrap; margin-bottom: 80px;">
      <div class="one-half column" style="background-color: #2c3e50 !important; display: flex; align-items: center; justify-content: center; padding: clamp(40px, 8vw, 60px) 15px; border-radius: 8px; width: 100%; max-width: 540px; min-height: auto;">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span style="font-size: clamp(2.2rem, 6vw, 4.2rem) !important; font-weight: 900 !important; line-height: 1;">高校生1年〜3年</span>
            <span style="font-size: clamp(2.8rem, 8vw, 5.5rem) !important; font-family: sans-serif; font-weight: bold; line-height: 1;">›</span>
          </div>
          <div style="margin-bottom: 25px;">
            <p style="font-size: clamp(1.4rem, 4vw, 2.4rem) !important; font-weight: bold !important; margin: 0 0 10px 0;">大学受験から学校の内申まで</p>
            <p style="font-size: clamp(1.4rem, 4vw, 2.4rem) !important; font-weight: 800 !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 6px 20px; border-radius: 50px; margin: 0;">自律型学習の確立</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 12px clamp(20px, 5vw, 45px); margin-top: 10px; width: fit-content; max-width: 95%;">
            <h3 style="font-size: clamp(1.8rem, 5vw, 3rem) !important; font-weight: 900 !important; color: #ffffff !important; margin: 0; white-space: nowrap;">「高校別サポート」</h3>
          </div>
        </div>
      </div>
      <div class="brief-tab one-half column" style="padding: 30px clamp(0px, 5vw, 50px); flex: 1; min-width: 300px;">
        <h3 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: bold; margin-bottom: 15px; line-height: 1.3;">目標に合わせた最短距離の学習</h3>
        <p style="font-size: 1.15rem; line-height: 1.6; color: #666; margin-bottom: 20px;">評定アップ、共通テスト対策。一人ひとりの目標に合わせて指導を設計します。</p>
        <a href="/highschool" style={btnStyle}>高校部を詳しく見る →</a>
      </div>
    </div>

  </div>
</section>

<style>
  .n-btn-hover:hover {
    background-color: #d35400 !important;
    transform: translateY(-3px);
  }
</style>