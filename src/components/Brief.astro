---
// 右側のアイコン用
import Bolt from '../assets/bolt.svg'
import Money from '../assets/money.svg'
import Wallet from '../assets/wallet.svg'
import Secure from '../assets/lock.svg'

// ボタンの共通スタイル
const btnStyle = "display: inline-block; margin-top: 30px; background: #001530; color: #fff; padding: 12px 35px; font-size: 1.1rem; border-radius: 50px; font-weight: 800; text-decoration: none; transition: 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.1);";
---

<section class="product-brief" id="features">
  <div class="container">

    <div class="row product-brief-items" style="display: flex; align-items: center; margin-bottom: 100px;">
      <div class="one-half column" style="background-color: #1a365d !important; min-height: 480px; display: flex; align-items: center; justify-content: center; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 25px; display: flex; align-items: center; justify-content: center; gap: 15px;">
            <span style="font-size: 4.2rem !important; font-weight: 900 !important; color: #ffffff !important; line-height: 1; letter-spacing: -0.02em;">小学生1年〜6年</span>
            <span style="font-size: 5.5rem !important; font-family: 'Arial Rounded MT Bold', 'Helvetica Rounded', sans-serif; font-weight: bold; color: #ffffff !important; line-height: 1; margin-top: -5px;">›</span>
          </div>
          <div style="margin-bottom: 30px;">
            <p style="font-size: 2.4rem !important; font-weight: bold !important; color: #ffffff !important; margin: 0 0 15px 0; letter-spacing: 0.05em;">考える力を養成する</p>
            <p style="font-size: 2.8rem !important; font-weight: 800 !important; color: #ffffff !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 5px 20px; border-radius: 50px; margin: 0;">絵解き算数教室</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 15px 45px; margin-top: 10px;">
            <h3 style="font-size: 3rem !important; font-weight: 900 !important; color: #ffffff !important; margin: 0;">「どんぐり倶楽部」</h3>
          </div>
        </div>
      </div>

      <div class="brief-tab one-half column" style="padding-left: 50px;">
        <h3 class="h2-title" style="font-size: 3.2rem; font-weight: bold; margin-bottom: 20px;">算数の応用問題を絵図を使いながら解きます</h3>
        <p class="m-paragraph m-margin" style="font-size: 1.1rem; line-height: 1.6; color: #666; margin-bottom: 30px;">
          絵図を書いて考えることで、子供たちの思考力を引き出し、算数の問題を解く楽しさを体験させます。
        </p>
        <div class="brief-items">
          <div class="row m-margin" style="display: flex; margin-bottom: 20px;">
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Fast">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">真の基礎学力の養成、ゆっくりじっくり考えます</p>
            </div>
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Value">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">絵図を書くことで、理解を深めます</p>
            </div>
          </div>
        </div>
        <a href="/donguri" style={btnStyle} class="n-btn-hover">どんぐりを詳しく見る →</a>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; margin-bottom: 100px;">
      <div class="brief-tab one-half column" style="padding-right: 50px;">
        <h3 class="h2-title" style="font-size: 3.2rem; font-weight: bold; margin-bottom: 20px;">短期で私立中学を受験するコースです</h3>
        <p class="m-paragraph m-margin" style="font-size: 1.1rem; line-height: 1.6; color: #666; margin-bottom: 30px;">
          大手の塾で朝から晩まで勉強付けは少し苦手、学力にあった学校に合格したい。短期集中で無理なく学びます。
        </p>
        <div class="brief-items">
          <div class="row m-margin" style="display: flex; margin-bottom: 20px;">
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Fast">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">入試科目を目標中学に合わせ、無駄な学習を減らします。</p>
            </div>
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Value">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">基礎をおろそかにせず、確実に得点に結びつけます。</p>
            </div>
          </div>
        </div>
        <a href="/chugakujuken" style={btnStyle} class="n-btn-hover">中学受験を詳しく見る →</a>
      </div>

      <div class="one-half column" style="background-color: #96514d !important; min-height: 480px; display: flex; align-items: center; justify-content: center; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 25px; display: flex; align-items: center; justify-content: center; gap: 15px;">
            <span style="font-size: 5.5rem !important; font-family: 'Arial Rounded MT Bold', 'Helvetica Rounded', sans-serif; font-weight: bold; color: #ffffff !important; line-height: 1; margin-top: -5px;">‹</span>
            <span style="font-size: 4.2rem !important; font-weight: 900 !important; color: #ffffff !important; line-height: 1; letter-spacing: -0.02em;">小学生5年, 6年</span>
          </div>
          <div style="margin-bottom: 30px;">
            <p style="font-size: 2.6rem !important; font-weight: bold !important; color: #ffffff !important; margin: 0;">短期集中で無理なく受験</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 15px 45px; margin-top: 10px;">
            <h3 style="font-size: 3rem !important; font-weight: 900 !important; color: #ffffff !important; margin: 0;">「中学受験コース」</h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; margin-bottom: 100px;">
      <div class="one-half column" style="background-color: #2d5a27 !important; min-height: 480px; display: flex; align-items: center; justify-content: center; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 25px; display: flex; align-items: center; justify-content: center; gap: 15px;">
            <span style="font-size: 4.2rem !important; font-weight: 900 !important; color: #ffffff !important; line-height: 1; letter-spacing: -0.02em;">中学生 1〜3年</span>
            <span style="font-size: 5.5rem !important; font-family: 'Arial Rounded MT Bold', 'Helvetica Rounded', sans-serif; font-weight: bold; color: #ffffff !important; line-height: 1; margin-top: -5px;">›</span>
          </div>
          <div style="margin-bottom: 30px;">
            <p style="font-size: 2.4rem !important; font-weight: bold !important; color: #ffffff !important; margin: 0 0 15px 0; letter-spacing: 0.05em;">学校の補習から定期テストまで</p>
            <p style="font-size: 2.4rem !important; font-weight: 800 !important; color: #ffffff !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 5px 20px; border-radius: 50px; margin: 0;">個別対応の学習支援</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 15px 45px; margin-top: 10px;">
            <h3 style="font-size: 3rem !important; font-weight: 900 !important; color: #ffffff !important; margin: 0;">「中学寺子屋コース」</h3>
          </div>
        </div>
      </div>

      <div class="brief-tab one-half column" style="padding-left: 50px;">
        <h3 class="h2-title" style="font-size: 3.2rem; font-weight: bold; margin-bottom: 20px;">定期テスト・内申対策</h3>
        <p class="m-paragraph m-margin" style="font-size: 1.1rem; line-height: 1.6; color: #666; margin-bottom: 30px;">
          寺子屋式で目の前で先生がしっかりサポートします。定期テスト無料補習で足りない部分を徹底サポート。
        </p>
        <div class="brief-items">
          <div class="row m-margin" style="display: flex; margin-bottom: 20px;">
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Fast">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">学校のワークやプリントを徹底活用します。</p>
            </div>
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Value">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">内申点アップを見据えた無料定期テスト補習。</p>
            </div>
          </div>
        </div>
        <a href="/chugakuterakoya" style={btnStyle} class="n-btn-hover">中学寺子屋を詳しく見る →</a>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; margin-bottom: 100px;">
      <div class="brief-tab one-half column" style="padding-right: 50px;">
        <h3 class="h2-title" style="font-size: 3.2rem; font-weight: bold; margin-bottom: 20px;">私立独自の早い進度に対応します</h3>
        <p class="m-paragraph m-margin" style="font-size: 1.1rem; line-height: 1.6; color: #666; margin-bottom: 30px;">
          検定教科書以外の教材や、公立とは異なるカリキュラム。私立ならではの悩みと進度を個別でサポート。
        </p>
        <div class="brief-items">
          <div class="row m-margin" style="display: flex; margin-bottom: 20px;">
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Fast">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">私立中学の特殊な教材・進度に完全対応。</p>
            </div>
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Value">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">内部進学に向けた成績維持を徹底サポート。</p>
            </div>
          </div>
        </div>
        <a href="/shiritsuchugaku" style={btnStyle} class="n-btn-hover">私立中サポートを詳しく見る →</a>
      </div>

      <div class="one-half column" style="background-color: #4a235a !important; min-height: 480px; display: flex; align-items: center; justify-content: center; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 25px; display: flex; align-items: center; justify-content: center; gap: 15px;">
            <span style="font-size: 5.5rem !important; font-family: 'Arial Rounded MT Bold', 'Helvetica Rounded', sans-serif; font-weight: bold; color: #ffffff !important; line-height: 1; margin-top: -5px;">‹</span>
            <span style="font-size: 4.2rem !important; font-weight: 900 !important; color: #ffffff !important; line-height: 1; letter-spacing: -0.02em;">私立中学 1〜3年</span>
          </div>
          <div style="margin-bottom: 30px;">
            <p style="font-size: 2.6rem !important; font-weight: bold !important; color: #ffffff !important; margin: 0;">一貫校のスピードに負けない</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 15px 45px; margin-top: 10px;">
            <h3 style="font-size: 3rem !important; font-weight: 900 !important; color: #ffffff !important; margin: 0;">「私立中サポート」</h3>
          </div>
        </div>
      </div>
    </div>

    <div class="row product-brief-items" style="display: flex; align-items: center; margin-bottom: 120px;">
      <div class="one-half column" style="background-color: #2c3e50 !important; min-height: 480px; display: flex; align-items: center; justify-content: center; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; width: 100%; color: #ffffff !important;">
          <div style="margin-bottom: 25px; display: flex; align-items: center; justify-content: center; gap: 15px;">
            <span style="font-size: 4.2rem !important; font-weight: 900 !important; color: #ffffff !important; line-height: 1; letter-spacing: -0.02em;">高校生1年〜3年</span>
            <span style="font-size: 5.5rem !important; font-family: 'Arial Rounded MT Bold', 'Helvetica Rounded', sans-serif; font-weight: bold; color: #ffffff !important; line-height: 1; margin-top: -5px;">›</span>
          </div>
          <div style="margin-bottom: 30px;">
            <p style="font-size: 2.4rem !important; font-weight: bold !important; color: #ffffff !important; margin: 0 0 15px 0; letter-spacing: 0.05em;">大学受験から学校の内申まで</p>
            <p style="font-size: 2.4rem !important; font-weight: 800 !important; color: #ffffff !important; background: rgba(255,255,255,0.1); display: inline-block; padding: 5px 20px; border-radius: 50px; margin: 0;">自律型学習の確立</p>
          </div>
          <div style="border: 3px solid #ffffff !important; display: inline-block; padding: 15px 45px; margin-top: 10px;">
            <h3 style="font-size: 3rem !important; font-weight: 900 !important; color: #ffffff !important; margin: 0;">「高校別サポート」</h3>
          </div>
        </div>
      </div>

      <div class="brief-tab one-half column" style="padding-left: 50px;">
        <h3 class="h2-title" style="font-size: 3.2rem; font-weight: bold; margin-bottom: 20px;">目標に合わせた最短距離の学習</h3>
        <p class="m-paragraph m-margin" style="font-size: 1.1rem; line-height: 1.6; color: #666; margin-bottom: 30px;">
          評定アップ、共通テスト対策、志望校別二次試験対策。一人ひとりの目標に合わせて指導を設計します。
        </p>
        <div class="brief-items">
          <div class="row m-margin" style="display: flex; margin-bottom: 20px;">
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Fast">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">小論文・総合型選抜対策や、英検対策も無料でサポート。</p>
            </div>
            <div class="one-half column feature-grid" style="display: flex; align-items: flex-start;">
              <img src={Bolt.src} style="width: 25px; margin-right: 15px; margin-top: 5px;" alt="Value">
              <p class="s-paragraph" style="margin: 0; font-size: 1rem;">全科目サポート。大学別の受験戦略を個別に構築します。</p>
            </div>
          </div>
        </div>
        <a href="/highschool" style={btnStyle} class="n-btn-hover">高校部を詳しく見る →</a>
      </div>
    </div>

  </div>
</section>

<style>
  .product-brief { background-color: var(--tenary); padding: 80px 0; }
  
  .n-btn-hover:hover {
    background-color: #d35400 !important;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
  }

  @media (max-width: 768px) {
    .row.product-brief-items { flex-direction: column !important; margin-bottom: 60px !important; text-align: center; }
    .row.product-brief-items:nth-child(even) { flex-direction: column-reverse !important; }
    .one-half.column { width: 100% !important; margin: 0 0 20px 0 !important; padding: 0 !important; }
    .brief-tab { padding: 20px 15px !important; }
    .n-btn-hover { width: 80%; margin: 20px auto 0 !important; }
    span[style*="font-size: 4.2rem"] { font-size: 2.4rem !important; }
    span[style*="font-size: 5.5rem"] { font-size: 3.4rem !important; }
    p[style*="font-size: 2.4rem"], p[style*="font-size: 2.6rem"] { font-size: 1.6rem !important; }
    h3[style*="font-size: 3rem"] { font-size: 2rem !important; }
  }
</style>