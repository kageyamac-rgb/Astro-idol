---
// LINE公式アカウントのURL
const lineUrl = "https://line.me/R/ti/p/@あなたのLINE_ID";
---

<section class="contact-section" id="contact">
  <div class="contact-container">
    <h2 class="contact-title">お問い合わせ</h2>
    <p class="contact-lead">入塾相談・体験授業のお申し込みは、LINEまたはメールフォームより承ります。</p>

    <div class="contact-stack">
      
      <div class="method-card line-border">
        <span class="recommend-badge">おすすめ</span>
        <h3 class="line-h3">LINEで無料体験を申し込む・相談する</h3>
        <p class="method-desc">
          「無料体験の予約」「そのほかの相談」という方は、LINEが最もスムーズです。<br/>
          お友達登録の後、保護者様のお名前、お子様のお名前、学年をご記入してご連絡ください。
        </p>
        <div class="btn-wrapper">
          <a href={lineUrl} class="line-round-btn" target="_blank" rel="noopener noreferrer">
            LINE友だち追加はこちら
          </a>
        </div>
      </div>

      <div class="method-card mail-border">
        <h3 class="mail-h3">メールフォーム</h3>
        <div class="notice-box">
          <p><strong>【重要】</strong> 毎年3月以降のお問い合わせは、<strong>「新学年」</strong>を選択してください。</p>
          <p class="reply-guide">
            ※通常、<strong>2日以内</strong>に返信いたします。万が一返信がない場合は、お手数ですが下記より直接メールの再送をお願いいたします。
          </p>
          <div class="mail-unlock-area">
            <button id="unlock-mail" class="unlock-mail-btn" type="button">📩 直接メールアドレスを表示する</button>
            <div id="mail-output"></div>
          </div>
        </div>
        
        <form name="contact" method="POST" data-netlify="true" action="/thanks">
          <input type="hidden" name="form-name" value="contact" />

          <div class="input-row">
            <label class="form-label">保護者様お名前<span>必須</span></label>
            <input type="text" name="parent_name" required placeholder="鳴滝 太郎" class="form-control" />
          </div>
          
          <div class="input-row">
            <label class="form-label">お子様の学年<span>必須</span></label>
            <select name="grade" required class="form-control">
              <option value="">選択してください</option>
              <option value="未就学">未就学児（小学生未満）</option>
              <option value="小1">小学1年生</option><option value="小2">小学2年生</option><option value="小3">小学3年生</option>
              <option value="小4">小学4年生</option><option value="小5">小学5年生</option><option value="小6">小学6年生</option>
              <option value="中1">中学1年生</option><option value="中2">中学2年生</option><option value="中3">中学3年生</option>
              <option value="高1">高校1年生</option><option value="高2">高校2年生</option><option value="高3">高校3年生</option>
              <option value="既卒">高校生以上（既卒・一般等）</option>
            </select>
          </div>

          <div class="input-row">
            <label class="form-label">メールアドレス<span>必須</span></label>
            <input type="email" name="email" required placeholder="example@mail.com" class="form-control" />
          </div>

          <div class="input-row">
            <label class="form-label">お問い合わせ内容</label>
            <textarea name="message" rows="5" placeholder="体験授業の希望日時など" class="form-control"></textarea>
          </div>

          <div class="btn-wrapper">
            <button type="submit" class="mail-round-btn">上記の内容で送信する</button>
          </div>
        </form>
      </div>

      <div class="method-card tel-border">
        <h3 class="tel-h3">お電話でのお問い合わせ</h3>
        <p class="method-desc">
          授業中などはお電話に出られない場合がございます。<br/>
          お電話は 10:00から20:00の間におかけください。
        </p>
        <div class="tel-unlock-area">
          <button id="unlock-tel" class="unlock-btn" type="button">📞 電話番号を表示する</button>
          <div id="tel-output"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // 電話
    const telBtn = document.getElementById('unlock-tel');
    if (telBtn) {
      telBtn.addEventListener('click', function() {
        const a = "042"; // 実際の番号に
        const b = "400"; 
        const c = "XXXX"; 
        const telNum = a + "-" + b + "-" + c;
        const output = document.getElementById('tel-output');
        output.innerHTML = '<a href="tel:' + a + b + c + '" class="real-tel">' + telNum + '<br><small>タップで発信できます</small></a>';
        this.style.display = 'none';
      });
    }
    // メール
    const mailBtn = document.getElementById('unlock-mail');
    if (mailBtn) {
      mailBtn.addEventListener('click', function() {
        const user = "mail";
        const domain = "narutakijuku.com";
        const addr = user + "@" + domain;
        const output = document.getElementById('mail-output');
        output.innerHTML = '<a href="mailto:' + addr + '" class="real-mail">' + addr + '</a>';
        this.style.display = 'none';
      });
    }
  });
</script>

<style>
  .contact-section { padding: 100px 20px; background-color: #f4f7f9; }
  .contact-container { max-width: 800px; margin: 0 auto; font-family: sans-serif; }
  .contact-title { text-align: center; font-size: 2.2rem; color: #001530; margin-bottom: 10px; font-weight: 800; }
  .contact-lead { text-align: center; margin-bottom: 50px; color: #555; font-weight: 600; }
  .contact-stack { display: flex; flex-direction: column; gap: 40px; }

  .method-card { background: #fff; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .line-border { border: 3px solid #06c755; text-align: center; }
  .mail-border { border: 1px solid #eee; }
  .tel-border { text-align: center; border: 1px solid #eee; }

  .recommend-badge { background: #06c755; color: #fff; padding: 4px 12px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; display: inline-block; }
  .line-h3 { color: #06c755; font-size: 1.8rem; margin: 15px 0; font-weight: 800; line-height: 1.4; }
  .mail-h3 { font-size: 1.6rem; margin-bottom: 25px; border-left: 6px solid #d35400; padding-left: 15px; color: #001530; font-weight: 800; }
  .tel-h3 { display: inline-block; font-size: 1.6rem; margin-bottom: 25px; color: #001530; font-weight: 800; padding-bottom: 8px; border-bottom: 3px dotted #d35400; }

  .method-desc { font-weight: 600; margin-bottom: 25px; line-height: 1.7; color: #333; }
  .notice-box { background: #fff5ee; border: 1px solid #ffccaa; padding: 25px; border-radius: 12px; margin-bottom: 30px; font-size: 1rem; color: #333; }
  .notice-box strong { color: #d35400; }
  .reply-guide { margin-top: 15px; padding-top: 15px; border-top: 1px dashed #ffccaa; }

  .input-row { margin-bottom: 25px; text-align: left; }
  .form-label { display: block; font-weight: 800; margin-bottom: 10px; color: #333; }
  .form-label span { color: #d35400; font-size: 0.8rem; margin-left: 8px; }
  .form-control { width: 100%; padding: 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; box-sizing: border-box; }

  .btn-wrapper { text-align: center; margin-top: 20px; }
  .line-round-btn, .mail-round-btn {
    display: inline-flex; align-items: center; justify-content: center; width: 100%; max-width: 400px;
    padding: 18px 40px; border-radius: 50px; font-size: 1.3rem; font-weight: 800; text-decoration: none; border: none; cursor: pointer; transition: 0.3s;
  }
  .line-round-btn { background-color: #06c755; color: #fff; box-shadow: 0 4px 15px rgba(6, 199, 85, 0.3); }
  .mail-round-btn { background-color: #d35400; color: #fff; box-shadow: 0 4px 15px rgba(211, 84, 0, 0.3); }
  .line-round-btn:hover, .mail-round-btn:hover { transform: translateY(-3px); opacity: 0.9; }

  .tel-unlock-area { margin-top: 20px; display: flex; justify-content: center; align-items: center; min-height: 80px; }
  .unlock-btn, .unlock-mail-btn { background: #f8f8f8; border: 1px solid #ddd; padding: 12px 30px; border-radius: 50px; font-weight: 800; cursor: pointer; transition: 0.2s; }
  .unlock-mail-btn { border-color: #d35400; color: #d35400; font-size: 1.1rem; margin-top: 10px; }

  :global(.real-tel) { display: block; font-size: 2.5rem; font-weight: 900; color: #001530; text-decoration: none; line-height: 1.2; animation: fadeIn 0.4s ease-out; }
  :global(.real-mail) { display: inline-block; font-size: 1.8rem; font-weight: 900; color: #d35400; text-decoration: underline; margin-top: 10px; animation: fadeIn 0.4s ease-out; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 768px) {
    .contact-title { font-size: 1.8rem; }
    .line-round-btn, .mail-round-btn { font-size: 1.15rem; }
    :global(.real-tel) { font-size: 1.8rem; }
    :global(.real-mail) { font-size: 1.4rem; }
  }
</style>