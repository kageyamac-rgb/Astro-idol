---
// hero.astro
import Feat1 from '../assets/etokisansu-lp.png'
import Feat2 from '../assets/chugakujuken-lp.png'
import Feat3 from '../assets/terakoyashiki-lp.png'
import Feat4 from '../assets/testtaisaku-lp.png'
import Feat5 from '../assets/kaikei-lp.png'
---

<section class="nj-ultimate-hero">
  <div class="nj-hero-canvas">
    
    <div class="nj-text-block">
      <h1 class="nj-title">一人ひとりを大切にして、考える力をはぐくむ少人数制の学習塾</h1>
      <h2 class="nj-sub-header">
        <span class="nj-caption">絵解き算数教室「どんぐり倶楽部準拠教室」</span><br />
        鳴滝塾
      </h2>
      
      <p class="nj-description">
        鳴滝塾はリニューアル。新しい3つのコースが始まります。<br />
        <strong class="nj-orange">小5からの中学受験 / 私立中学生コース / 通塾してない高校生</strong><br />
        移転し新しくなった教室で、考える力を育む時間を共に過ごしましょう。
      </p>

      <div class="nj-cta">
        <a href="#contact" class="nj-btn">まずは無料体験授業 →</a>
      </div>
    </div>

    <div class="nj-image-group">
      <img src={Feat1.src} alt="強み1" class="nj-img nj-i1">
      <img src={Feat2.src} alt="強み2" class="nj-img nj-i2">
      <img src={Feat3.src} alt="強み3" class="nj-img nj-i3">
      <img src={Feat4.src} alt="強み4" class="nj-img nj-i4">
      <img src={Feat5.src} alt="強み5" class="nj-img nj-i5">
    </div>

  </div>
</section>

<style lang="scss">
/* ============================================================
   【基本設定】
============================================================ */
.nj-ultimate-hero {
  position: relative;
  width: 100%;
  background-color: #fff;
  overflow: hidden;
  padding: 100px 0 !important; // ヘッダーとの隙間
}

.nj-hero-canvas {
  position: relative;
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  min-height: 650px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 中央の文字エリア（絶対に画像に負けない設定） */
.nj-text-block {
  position: relative;
  z-index: 999; /* 他の全てより手前に */
  max-width: 600px;
  text-align: center;
}

.nj-title { font-size: 2.2rem; font-weight: 800; color: #001530; margin-bottom: 20px; line-height: 1.4; }
.nj-sub-header {
  font-size: 4rem; font-weight: 900; line-height: 1; margin: 30px 0;
  .nj-caption { display: block; font-size: 1.6rem; color: #444; margin-bottom: -10px; }
}
.nj-description { font-size: 1.4rem; line-height: 1.8; color: #333; .nj-orange { color: #d35400; font-weight: 800; } }

/* ============================================================
   【PC版：1000px以上】画像を散らす
============================================================ */
@media (min-width: 1000px) {
  .nj-image-group {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
  }

  .nj-img {
    position: absolute !important;
    display: block !important;
    height: auto !important;
    z-index: 10;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.1));
    transform: none !important; /* 回転を禁止 */

    /* サイズを px で強制固定（Skeletonに負けない） */
    &.nj-i1 { top: 0; left: 0; width: 180px !important; }         // 左上
    &.nj-i2 { top: 0; right: 0; width: 180px !important; }        // 右上
    &.nj-i3 { bottom: 120px; left: 20px; width: 160px !important; }  // 左下
    &.nj-i4 { bottom: 120px; right: 20px; width: 160px !important; } // 右下
    
    // 一番下の画像：ボタンと被らないようにさらに下げる
    &.nj-i5 { 
      bottom: -100px; 
      left: 50%; 
      transform: translateX(-50%) !important; 
      width: 240px !important; 
    }
  }
}

/* ボタン装飾 */
.nj-btn {
  display: inline-block;
  background-color: #d35400;
  color: #fff !important;
  padding: 16px 45px;
  border-radius: 50px;
  font-weight: 800;
  font-size: 1.3rem;
  text-decoration: none;
  box-shadow: 0 10px 20px rgba(211, 84, 0, 0.2);
  margin-top: 20px;
}

/* ============================================================
   【スマホ版：999px以下】縦並びに切り替え
============================================================ */
@media (max-width: 999px) {
  .nj-ultimate-hero { padding: 100px 20px 60px !important; }

  .nj-hero-canvas {
    flex-direction: column;
    min-height: auto;
  }

  .nj-text-block {
    max-width: 100%;
    margin-bottom: 50px;
  }

  /* 文字サイズ調整 */
  .nj-title { font-size: 1.8rem; }
  .nj-sub-header { font-size: 3rem; .nj-caption { font-size: 1.3rem; } }

  /* 画像を絶対配置から「解除」して縦に並べる（巨大化防止） */
  .nj-image-group {
    position: static;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
    width: 100%;

    .nj-img {
      position: static !important;
      transform: none !important;
      width: 85% !important; /* スマホ画面に合わせる */
      max-width: 280px !important; /* 巨大化を物理的に阻止 */
      margin: 0 auto;
    }
  }
}
</style>