---
/* 授業料セクション：千の位以上を強調＆オールオレンジ価格（完全修正版） */
---

<section class="pricing-section" id="pricing">
  <div class="container">
    <div class="center-title">
      <span class="sub-title">PRICING</span>
      <h2 class="section-title">授業料のご案内</h2>
    </div>

    <div class="pricing-grid">
      
      <div class="price-column border-primary">
        <div class="column-tag primary">ELEMENTARY</div>
        <h3 class="category-title">小学生<span>の授業</span></h3>
        
        <div class="items-wrap">
          <a href="/courses#donguri" class="course-card">
            <div class="card-info">
              <span class="category-label">絵解き算数教室(小1〜6)</span>
              <span class="course-name">どんぐり倶楽部</span>
            </div>
            <div class="arrow-circle">&gt;</div>
          </a>
          <div class="price-box">
            <span class="price-orange"><span class="big-num">8</span>,000</span><span class="unit">円～(4回/月)</span><br>
            <span class="price-orange"><span class="big-num">15</span>,000</span><span class="unit">円～(8回/月)</span>
          </div>

          <a href="/courses#junior-exam" class="course-card">
            <div class="card-info">
              <span class="category-label">小5,6</span>
              <span class="course-name">私立中学受験コース</span>
            </div>
            <div class="arrow-circle">&gt;</div>
          </a>
          <div class="free-info">入試前対策無料補習</div>
          <div class="price-rows">
            <div class="price-line">
              <span class="line-label">小6</span>
              <span class="price-orange"><span class="big-num">36</span>,000</span><span class="unit">円(～20回/月)</span>
            </div>
            <div class="price-line">
              <span class="line-label">小5</span>
              <span class="price-orange"><span class="big-num">24</span>,000</span><span class="unit">円(　 8回/月)</span>
            </div>
          </div>
        </div>
      </div>

      <div class="price-column border-secondary featured">
        <div class="column-tag secondary">JUNIOR HIGH</div>
        <h3 class="category-title">中学生<span>の授業</span></h3>
        
        <div class="items-wrap">
          
          <a href="/courses#junior-high" class="course-card">
            <div class="card-info">
              <span class="category-label">五教科対応</span>
              <span class="course-name">寺子屋式学習</span>
            </div>
            <div class="arrow-circle">&gt;</div>
          </a>
          <div class="free-info top-offset">テスト前対策無料補習</div>
          <div class="price-rows">
            <div class="price-line">
              <span class="line-label">中1.2</span>
              <span class="price-orange"><span class="big-num">21</span>,000</span><span class="unit">円(8回/月)</span>
            </div>
            <div class="price-line">
              <span class="line-label">中3</span>
              <span class="price-orange"><span class="big-num">23</span>,000</span><span class="unit">円(8回/月)</span>
            </div>
          </div>

          <a href="/courses#private-support" class="course-card">
            <div class="card-info">
              <span class="category-label">中学1年〜3年</span>
              <span class="course-name">私立中学サポート</span>
            </div>
            <div class="arrow-circle">&gt;</div>
          </a>
          <div class="free-info top-offset">テスト前対策無料補習</div>
          <div class="price-box">
            <span class="price-orange"><span class="big-num">24</span>,000</span><span class="unit">円(8回/月)</span>
          </div>
        </div>
      </div>

      <div class="price-column border-tertiary">
        <div class="column-tag tertiary">HIGH SCHOOL</div>
        <h3 class="category-title">高校生<span>の授業</span></h3>
        
        <div class="items-wrap">
          
          <a href="/courses#high-school" class="course-card">
            <div class="card-info">
              <span class="category-label">内申・推薦・受験指導対応</span>
              <span class="course-name">高校別サポート</span>
            </div>
            <div class="arrow-circle">&gt;</div>
          </a>
          <div class="free-info top-offset">テスト前対策無料補習</div>
          <div class="price-rows">
            <div class="price-line">
              <span class="line-label">高1.2</span>
              <span class="price-orange"><span class="big-num">27</span>,000</span><span class="unit">円(8回/月)</span>
            </div>
            <div class="price-line">
              <span class="line-label">高3</span>
              <span class="price-orange"><span class="big-num">36</span>,000</span><span class="unit">円(8回/月)</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style lang="scss">
  .pricing-section {
    padding: 120px 20px;
    background-color: #fcfcfc;
    .container { max-width: 1200px; margin: 0 auto; }
  }

  .center-title {
    text-align: center;
    margin-bottom: 80px;
    .sub-title { color: #d35400; font-size: 0.9rem; font-weight: bold; letter-spacing: 0.2em; }
    .section-title { font-size: 2.5rem; color: #001530; font-weight: 800; margin-top: 10px; }
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .price-column {
    background: #fff;
    padding: 60px 20px 40px;
    border-radius: 20px;
    position: relative;
    border: 3px solid #eee;
    
    &.border-primary { border-color: #d35400; } 
    &.border-secondary { border-color: #001530; } 
    &.border-tertiary { border-color: #bdc3c7; } 

    &.featured {
      transform: translateY(-10px);
      box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }
  }

  .column-tag {
    position: absolute;
    top: -15px;
    left: 20px;
    padding: 6px 15px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 900;
    color: #fff;
    &.primary { background: #d35400; }
    &.secondary { background: #001530; }
    &.tertiary { background: #7f8c8d; }
  }

  .category-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: #001530;
    margin-bottom: 40px;
    text-align: center;
    span { font-size: 1rem; font-weight: 500; opacity: 0.7; }
  }

  .course-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    background: #fdfdfd;
    padding: 18px;
    border-radius: 12px;
    margin-bottom: 15px;
    border: 1px solid #f0f0f0;
    transition: all 0.3s ease;

    &:hover {
      background: #fff;
      border-color: #d35400;
      .arrow-circle { background: #d35400; color: #fff; border-color: #d35400; }
    }
  }

  .card-info {
    .category-label { display: block; font-size: 1.2rem; color: #333; margin-bottom: 4px; }
    .course-name { 
      display: block; 
      font-size: 1.8rem; 
      font-weight: 900; 
      color: #001530; 
      line-height: 1.2;
    }
  }

  .arrow-circle {
    width: 32px;
    height: 32px;
    border: 1.5px solid #001530;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #001530;
    font-weight: bold;
  }

  /* --- 金額パーツ：ここに修正を集中させました --- */
  .price-orange {
    color: #d35400 !important; /* 何があってもオレンジにする */
    font-weight: 800;
    font-size: 1.8rem;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
  }

  .big-num {
    font-size: 3.2rem !important; /* 何があっても大きくする */
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .unit {
    font-size: 1rem;
    color: #444;
    font-weight: 600;
    margin-left: 5px;
  }

  .price-box {
    text-align: right;
    margin-bottom: 35px;
  }

  .price-rows {
    margin-bottom: 35px;
    .price-line {
      display: flex;
      justify-content: flex-end;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 12px;

      /* 「小6」などのラベルのみをグレーに指定 */
      .line-label {
        font-size: 1.5rem;
        font-weight: bold;
        color: #444;
      }
    }
  }

  .free-info {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 800;
    color: #d35400;
    background: #fff5ee;
    padding: 5px 12px;
    border-radius: 4px;
    margin-bottom: 10px;
    &.top-offset { margin-bottom: 20px; }
  }

  @media (max-width: 950px) {
    .pricing-grid { grid-template-columns: 1fr; gap: 40px; }
    .price-column.featured { transform: none; }
  }
</style>