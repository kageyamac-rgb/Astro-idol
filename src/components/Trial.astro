---
/* src/components/Trial.astro */
---
<section class="trial-section">
  <div class="container">
    <div class="product-cta">
      <a href="/contact" class="btn-trial">
        <span class="btn-text">まずは無料体験授業</span>
        <span class="btn-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style lang="scss">
  .trial-section {
    padding: 20px 0 60px; // 上の余白を詰め、下の余白を広げて画像との距離を取る
    background-color: transparent; // 必要に応じて背景色を指定
    text-align: center;
  }

  .btn-trial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    
    /* サイズ微調整：横幅の存在感は残しつつ、上下をスリムに */
    width: auto;
    min-width: 320px; 
    padding: 14px 40px; // 18pxから14pxに縮小
    
    background-color: #d35400;
    color: #fff;
    text-decoration: none;
    font-weight: 800;
    font-size: 1.2rem; // 1.4remから1.2remに縮小
    border-radius: 50px;
    box-shadow: 0 8px 20px rgba(211, 84, 0, 0.15);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);

    &:hover {
      background-color: #e67e22;
      transform: translateY(-2px);
      box-shadow: 0 12px 25px rgba(211, 84, 0, 0.25);
      
      .btn-arrow {
        transform: translateX(6px);
      }
    }

    .btn-arrow {
      display: flex;
      align-items: center;
      transition: transform 0.3s ease;
    }
  }

  @media (max-width: 700px) {
    .btn-trial {
      width: 90%;
      min-width: unset;
    }
  }
</style>