---
// 1. 画像のインポート（パスがプロジェクトに合わせて正しいか確認してください）
import Bolt from '../assets/bolt.svg'
import Money from '../assets/money.svg'
import Wallet from '../assets/wallet.svg'
import Secure from '../assets/lock.svg'
---

<section class="nj-system-section" id="timetable">
  <div class="nj-container">
    
    <div class="nj-center-title">
      <span class="nj-sub-title">SYSTEM & SCHEDULE</span>
      <h2 class="nj-section-title">コース別スケジュール・時間帯</h2>
    </div>

    <div class="nj-grid">
      
      <div class="nj-column nj-is-elementary">
        <div class="nj-column-tag">ELEMENTARY</div>
        <div class="nj-content-inner">
          <h3 class="nj-category-title">小学生<span>のスケジュール</span></h3>
          
          <div class="nj-items-wrap">
            <div class="nj-course-header">
              <span class="nj-course-label">絵解き算数 (小1〜6)</span>
              <span class="nj-course-name">どんぐり倶楽部(1コマ１時間)</span>
            </div>
            
            <div class="nj-info-block nj-dot-blue">
              <div class="nj-time-row">
                <span class="nj-tag-icon">フ</span>
                <span class="nj-days">月火水金</span>
                <span class="nj-time-text">17:00 - 19:00</span>
                <span class="nj-note">(内1時間)</span>
              </div>
              <div class="nj-time-row">
                <span class="nj-tag-icon">固</span>
                <span class="nj-days">土曜日</span>
                <span class="nj-time-text">10:00 - 11:00 / 11:00 - 12:00</span>
                <span class="nj-note">(各1h)</span>
              </div>
              <ul class="nj-rule-list">
                <li>平日はフレックス制。お子様の都合の良いタイミングでスタート。</li>
                <li>土曜は時間固定制です。</li>
                <li class="nj-alert">18:00以降開始でも、19:00終了となります。</li>
              </ul>
            </div>

            <div class="nj-course-header nj-mt-offset">
              <span class="nj-course-label">小5,6</span>
              <span class="nj-course-name">中学受験コース(1コマ2時間)</span>
            </div>
            <div class="nj-info-block nj-dot-red">
              <div class="nj-common-time-badge">
                月火水金 17:00-19:00 / 土 10:00-12:00
              </div>
              <div class="nj-grade-row">
                <span class="nj-grade-label">小6</span>
                <span class="nj-time-text">週 3 〜 5 コマ</span>
                <span class="nj-unit">(定額)</span>
              </div>
              <ul class="nj-rule-list">
                <li>追加料金なしで週3〜5回通塾可能。とことん学習時間を確保。</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="nj-column nj-is-junior nj-featured">
        <div class="nj-column-tag">JUNIOR HIGH</div>
        <div class="nj-content-inner">
          <h3 class="nj-category-title">中学生<span>のスケジュール</span></h3>
          <div class="nj-items-wrap">
            <div class="nj-course-header">
              <span class="nj-course-label">五教科対応</span>
              <span class="nj-course-name">寺子屋式学習</span>
            </div>
            <div class="nj-info-block nj-dot-dark">
              <div class="nj-time-row"><span class="nj-grade-label">新中1</span><span class="nj-days">水、土</span><span class="nj-time-text">19:30 - 21:30</span></div>
              <div class="nj-time-row"><span class="nj-grade-label">新中2</span><span class="nj-days">月、金</span><span class="nj-time-text">19:30 - 21:30</span></div>
              <div class="nj-time-row"><span class="nj-grade-label">新中3</span><span class="nj-days">火土</span><span class="nj-time-text">19:30 - 21:30</span></div>
            </div>

            <div class="nj-course-header nj-mt-offset">
              <span class="nj-course-label">中学1年〜3年</span>
              <span class="nj-course-name">私立中学サポート</span>
            </div>
            <div class="nj-info-block nj-dot-dark">
              <div class="nj-grade-row">
                <span class="nj-grade-label">全学年</span>
                <span class="nj-time-text">週 2 回 (1回2h)</span>
              </div>
              <div class="nj-time-row">
                <span class="nj-tag-icon">フ</span>
                <span class="nj-days">月火水金土</span>
                <span class="nj-time-text">17:00 - 22:00</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="nj-column nj-is-high">
        <div class="nj-column-tag">HIGH SCHOOL</div>
        <div class="nj-content-inner">
          <h3 class="nj-category-title">高校生<span>のスケジュール</span></h3>
          <div class="nj-items-wrap">
            <div class="nj-course-header">
              <span class="nj-course-label">推薦・受験指導対応</span>
              <span class="nj-course-name">高校別サポート</span>
            </div>
            <div class="nj-info-block nj-dot-gray">
              <div class="nj-time-row"><span class="nj-days">月 〜 金</span><span class="nj-time-text">19:15 - 21:15</span></div>
              <div class="nj-grade-row">
                <span class="nj-grade-label">高1〜3</span>
                <span class="nj-time-text">週 2 回</span>
                <span class="nj-unit">(1回2h)</span>
              </div>
              <ul class="nj-rule-list">
                <li>フレックス制。22:00まで対応。</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* 色の管理 */
  :root {
    --nj-orange: #d35400;
    --nj-navy: #001530;
    --nj-gray: #7f8c8d;
    --nj-bg-light: #fcfcfc;
  }

  .nj-system-section {
    padding: 120px 20px;
    background-color: var(--nj-bg-light);
  }

  /* Priceと揃えて1200pxに変更 */
  .nj-container {
    max-width: 1200px; 
    margin: 0 auto;
    width: 100%;
  }

  .nj-center-title { text-align: center; margin-bottom: 80px; }
  .nj-sub-title { color: var(--nj-orange); font-size: 0.9rem; font-weight: bold; letter-spacing: 0.2em; display: block; }
  .nj-section-title { font-size: 2.5rem; color: var(--nj-navy); font-weight: 800; margin-top: 10px; }

  /* グリッドレイアウト：Gapを30pxに拡大 */
  .nj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px; 
    align-items: stretch;
    width: 100%;
  }

  /* カラム設定：ここから背景色を削除しました */
  .nj-column {
    /* background: #fff;  <--- これを削除 */
    padding: 60px 25px 40px; 
    border-radius: 20px;
    position: relative;
    border: 3px solid #eee;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.3s ease;
  }

  /* --- ここで背景色を復活させました --- */
  .nj-is-elementary {
    border-color: var(--nj-orange);
    background-color: #fffbf8; /* うっすらオレンジ */
  }
  .nj-is-junior {
    border-color: var(--nj-navy);
    background-color: #f4f7f9; /* うっすらネイビー */
  }
  .nj-is-high {
    border-color: #bdc3c7;
    background-color: #f9f9f9; /* うっすらグレー */
  }

  .nj-featured {
    transform: translateY(-10px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.08);
  }

  .nj-column-tag {
    position: absolute;
    top: -15px;
    left: 20px;
    padding: 6px 15px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 900;
    color: #fff;
  }
  .nj-is-elementary .nj-column-tag { background: var(--nj-orange); }
  .nj-is-junior .nj-column-tag { background: var(--nj-navy); }
  .nj-is-high .nj-column-tag { background: var(--nj-gray); }

  .nj-category-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--nj-navy);
    margin-bottom: 40px;
    text-align: center;
  }
  .nj-category-title span { font-size: 1rem; font-weight: 500; opacity: 0.7; }

  .nj-course-name { font-size: 1.5rem; font-weight: 900; color: #1a365d; line-height: 1.2; display: block; margin-bottom: 10px; }
  .nj-mt-offset { margin-top: 35px; }

  .nj-info-block { padding: 20px 15px; border-radius: 18px; border: 3px dotted #eee; background: #fff; margin-bottom: 15px; }
  .nj-time-text { color: var(--nj-orange); font-weight: 800; font-size: 1.2rem; }
  .nj-time-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .nj-tag-icon { background: #1a365d; color: #fff; font-size: 0.65rem; padding: 2px 5px; border-radius: 4px; font-weight: 900; }
  
  .nj-rule-list { margin: 15px 0 0 0; padding: 12px 0 0 0; list-style: none; border-top: 1.2px solid rgba(0,0,0,0.06); }
  .nj-rule-list li { font-size: 0.85rem; color: #444; font-weight: 700; margin-bottom: 4px; padding-left: 15px; position: relative; }
  .nj-rule-list li::before { content: "●"; position: absolute; left: 0; font-size: 0.5rem; top: 0.3rem; color: #ccc; }
  .nj-rule-list li.nj-alert { color: var(--nj-orange); }

  @media (max-width: 950px) {
    .nj-grid { grid-template-columns: 1fr; gap: 40px; }
    .nj-featured { transform: none; }
  }
</style>