---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="鳴滝塾 - 尾張旭市の少人数制学習塾">
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/skeleton/2.0.4/skeleton.min.css">
  </head>
  <body>
    <slot />
  </body>
</html>

<style lang="scss" is:global>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap');

  :root {
    --accent: #cc4b06;
    --dark: #001530; /* Aboutページで使った紺色に合わせる */
    --tenary: #ecf7f8;
    --base-font: 'Manrope', sans-serif;
  }

  html, body {
    font-family: var(--base-font);
    margin: 0px;
    scroll-behavior: smooth;
    /* 背景のグラデーションが About ページの真っ白と干渉する場合は調整してください */
    background-image: linear-gradient(to top, #dfe9f3 0%, white 100%);
    color: #333;
  }

  /* 本文のサイズを About ページの 1.5rem に統一 */
  p {
    font-size: 1.5rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  /* 見出しのサイズ感を調整（Aboutページのh2: 2.2rem等と喧嘩しないように） */
  .h1-title {
    font-size: 4rem;
    font-weight: 700;
    color: var(--dark);
  }
  .h2-title {
    font-size: 2.8rem; /* 少しだけ抑える */
    font-weight: 700;
    color: var(--dark);
  }

  .s-paragraph {
    font-size: 1.2rem;
  }

  .button {
    border-radius: 8px;
    height: auto;
    padding: 10px 30px;
    line-height: 1.5;
    &.button-primary {
      background: var(--accent);
      border: var(--accent);
      color: #fff;
    }
    &:hover {
      opacity: .8;
    }
  }

  section {
    padding: 80px 0; /* Aboutページの余白感に合わせる */
  }

  .center { 
    text-align: center; 
  }

  /* ヘルパークラス */
  .flex { display: flex; &.center { justify-content: center; } }
  .block { display: block; }

</style>